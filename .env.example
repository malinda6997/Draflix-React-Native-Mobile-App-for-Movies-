# Google Sign-In Configuration Template
# Uses Clerk OAuth - No direct Google Sign-In library needed!
# Copy to .env.local and fill in your actual values

# Clerk Configuration (REQUIRED)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_KEY

# To enable Google OAuth:
# 1. Go to https://dashboard.clerk.com
# 2. Select your app → Authenticators → Social
# 3. Enable Google OAuth
# 4. Sign in automatically works - UI handles it!

# Optional: TMDB API
TMDB_API_KEY=your_tmdb_api_key_here
